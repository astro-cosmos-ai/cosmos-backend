SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-public-key
ASTROLOGY_API_KEY=your-astrology-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
DEBUG=false

# Chart engine: "astrology_api" (default, requires ASTROLOGY_API_KEY) or "swiss" (local, no API key needed)
CHART_ENGINE=astrology_api
# Vedic ayanamsa: lahiri (default), raman, krishnamurti, yukteshwar
AYANAMSA=lahiri
# Rahu/Ketu node mode: mean (default, matches AstrologyAPI) or true
NODE_MODE=mean
